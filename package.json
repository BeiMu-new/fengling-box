{
  "name": "fengling-box",
  "version": "1.0.9",
  "description": "枫铃工具箱 — 多功能命令行工具箱，含多源聚合搜索（内置anysearch无需额外安装）、文件批处理、图片处理、信源核实、token计算、二维码生成、文件服务器等功能",
  "main": "src/index.js",
  "type": "module",
  "bin": {
    "flb": "./bin/flb.js"
  },
  "scripts": {
    "test": "node bin/flb.js --version"
  },
  "keywords": [
    "search",
    "toolbox",
    "cli",
    "file",
    "image",
    "data",
    "fengling",
    "anysearch",
    "token",
    "qr",
    "ascii",
    "commit",
    "server"
  ],
  "author": "BeiMu-new",
  "repository": {
    "type": "git",
    "url": "https://github.com/BeiMu-new/fengling-box"
  },
  "homepage": "https://www.npmjs.com/package/fengling-box",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.7.0",
    "chalk": "^5.3.0",
    "cheerio": "^1.0.0",
    "commander": "^12.1.0",
    "conf": "^13.0.0",
    "gpt-tokens": "^1.3.14",
    "node-fetch": "^3.3.2",
    "ora": "^8.0.1",
    "qrcode-terminal": "^0.12.0",
    "sharp": "^0.33.4",
    "table": "^6.8.2",
    "xlsx": "^0.18.5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "allowScripts": {
    "sharp@0.33.5": true
  }
}
